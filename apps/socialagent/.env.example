# === Telegram Bot ===
# Get from @BotFather on Telegram: https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=
# Random secret for webhook verification (generate with: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=

# === Database ===
# Postgres connection string (the setup script creates this DB automatically)
DATABASE_URL=postgres://socialagent:socialagent@localhost:5433/socialagent?sslmode=disable

# === Harness ===
# URL where harnessd is running
HARNESS_URL=http://localhost:8080

# === OpenAI ===
# Your OpenAI API key (also used by harnessd)
OPENAI_API_KEY=

# === Social Agent Server ===
# Address the socialagent HTTP server listens on
LISTEN_ADDR=:8081

# === System Prompt ===
# The agent's personality (optional, has a default)
# SOCIALAGENT_SYSTEM_PROMPT=
